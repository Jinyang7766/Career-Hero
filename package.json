{
  "name": "career-hero",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "cd ai-resume-builder && npm install && npm run build",
    "dev": "cd ai-resume-builder && npm run dev",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "npm --prefix ai-resume-builder run -s test",
    "test:backend": "python -m pytest backend/tests -q"
  },
  "workspaces": [
    "ai-resume-builder"
  ],
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
