# Supabase Configuration
# 获取方式：访问 https://supabase.com/dashboard → 选择项目 → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# JWT Secret
JWT_SECRET=your-jwt-secret-key

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
RAG_ENABLED=1
GEMINI_PDF_OCR_MODEL=gemini-3-flash-preview
GEMINI_RESUME_PARSE_MODEL=gemini-3-flash-preview
# Optional JD screenshot OCR model (defaults to GEMINI_PDF_OCR_MODEL if unset)
GEMINI_JD_OCR_MODEL=gemini-2.5-flash-lite
# Optional fallback list for JD screenshot OCR, comma-separated
GEMINI_JD_OCR_FALLBACK_MODELS=gemini-3-flash-preview
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash-lite
# Optional fallback list, comma-separated
GEMINI_TRANSCRIBE_FALLBACK_MODELS=gemini-2.5-flash
# Analysis speed knobs
# 1 = prefer faster flash models before pro model
ANALYSIS_SPEED_PRIORITY=0

# PDF parse performance knobs
# 1 = use concise parse prompt first (faster), then fallback to full prompt on failure
RESUME_PARSE_FAST_PROMPT_ENABLED=1
# AI parse timeout (seconds) for fast prompt
RESUME_PARSE_AI_TIMEOUT_SECONDS=18
# AI parse timeout (seconds) for fallback full prompt
RESUME_PARSE_AI_FALLBACK_TIMEOUT_SECONDS=28
# 1 = enable second-pass repair call (slower but may improve completeness)
RESUME_PARSE_SECOND_PASS_ENABLED=0
# OCR call timeout per request/model (seconds)
OCR_CALL_TIMEOUT_SECONDS=12
# OCR max pages to render from PDF
OCR_MAX_PAGES=3
# 1 = enable per-page OCR fallback (much slower)
OCR_PER_PAGE_FALLBACK_ENABLED=0

# PDF font configuration (for Chinese text rendering)
PDF_FONT_PATH=/absolute/path/to/font.ttf
PDF_FONT_NAME=CustomPDF
# PDF export concurrency guard (Playwright is resource-heavy)
# max concurrent PDF jobs per backend instance
PDF_EXPORT_MAX_CONCURRENCY=1
# seconds to wait for a free slot; set negative value to wait forever
PDF_EXPORT_ACQUIRE_TIMEOUT_SECONDS=8
# Optional explicit patch/version label for PDF export response header
# If empty, backend falls back to Git commit SHA or "pdf-export-dev"
PDF_EXPORT_PATCH_VERSION=

USE_MOCK_STORAGE=false

# PII guard mode for /api/ai/analyze:
# - warn: allow request, but return a warning when PII is detected
# - reject: block request when PII is detected
# - mask: replace name/phone/email with placeholders before AI call,
#         then restore them in AI output
PII_GUARD_MODE=warn

# Anti-bot / anti-crawler guard (server-side)
# ANTI_BOT_MODE: off | log | enforce
ANTI_BOT_ENABLED=1
ANTI_BOT_MODE=enforce
# Global API limit per (IP + User-Agent)
ANTI_BOT_GLOBAL_MAX_REQUESTS=120
ANTI_BOT_GLOBAL_WINDOW_SECONDS=60
# Auth endpoints: /api/auth/*
ANTI_BOT_AUTH_MAX_REQUESTS=25
ANTI_BOT_AUTH_WINDOW_SECONDS=60
# Heavy endpoints: /api/ai/*, /api/parse-pdf, /api/export-pdf
ANTI_BOT_HEAVY_MAX_REQUESTS=20
ANTI_BOT_HEAVY_WINDOW_SECONDS=60
# Block obvious bot clients by User-Agent (curl/python-requests/scrapy/etc.)
ANTI_BOT_BLOCK_KNOWN_UA=1
# Comma-separated UA keywords to always allow
ANTI_BOT_ALLOWED_UA_KEYWORDS=mozilla,chrome,safari,firefox,edg
# Comma-separated API path prefixes to bypass anti-bot checks
ANTI_BOT_BYPASS_PATHS=/api/internal/sweep-expired-deletions
