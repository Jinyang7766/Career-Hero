# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key
JWT_SECRET=your-jwt-secret

# Google Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_PDF_OCR_MODEL=gemini-3-flash-preview
GEMINI_RESUME_PARSE_MODEL=gemini-3-flash-preview
# Google Cloud Speech-to-Text (REST API Key)
# Note: this is NOT the Gemini API key.
GOOGLE_SPEECH_API_KEY=AIza...
# PDF export concurrency guard (Playwright is resource-heavy)
PDF_EXPORT_MAX_CONCURRENCY=1
PDF_EXPORT_ACQUIRE_TIMEOUT_SECONDS=8
PDF_EXPORT_PATCH_VERSION=

# Frontend Configuration (for deployment)
REACT_APP_API_URL=https://your-backend-url.onrender.com

USE_MOCK_STORAGE=false

# PII guard mode for /api/ai/analyze:
# - warn: allow request, but return a warning when PII is detected
# - reject: block request when PII is detected
# - mask: replace name/phone/email with placeholders before AI call,
#         then restore them in AI output
PII_GUARD_MODE=warn
