# Supabase Configuration
# 获取方式：访问 https://supabase.com/dashboard → 选择项目 → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# JWT Secret
JWT_SECRET=your-jwt-secret-key

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
RAG_ENABLED=1

# Google Cloud Speech-to-Text (REST API Key)
# Note: this is NOT the Gemini API key. You must enable "Cloud Speech-to-Text API" in the same GCP project.
GOOGLE_SPEECH_API_KEY=AIza...

# PDF font configuration (for Chinese text rendering)
PDF_FONT_PATH=/absolute/path/to/font.ttf
PDF_FONT_NAME=CustomPDF
